model Property {
    id String @id @default(uuid())

    title       String   @db.VarChar(255)
    description String?
    monthlyRent Float
    division    Division
    district    District
    address     String   @db.VarChar(255)

    // forign key
    landlordId String
    categoryId String
    request    Request[]
    // reference
    lanlord    User      @relation(fields: [landlordId], references: [id], onDelete: Cascade)
    category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

    status        PropertyStatus
    floor         Int
    image         String?
    availableFrom DateTime

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([landlordId])
    @@index([categoryId])
    @@map("properties")
}
