model User {
    id       String     @id @default(uuid())
    name     String     @db.VarChar(255)
    email    String     @unique
    password String
    status   UserStatus @default(ACTIVE)
    role     Role       @default(TENANT)

    properties Property[]
    requests   Request[]
    payments   Payment[]
    rentals    Rental[]

    profilePhoto String?
    bio          String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    reviews   Review[]

    @@map("users")
}
